# ──────────────────────────────────────────────
#  Gestor Financeiro — Variáveis de Ambiente
#  Copie para .env e preencha os valores reais
# ──────────────────────────────────────────────

# Conexão PostgreSQL
DATABASE_URL=postgresql://gestor:gestor123@localhost:5432/gestor_db

# SSL para PostgreSQL (true em produção com certificado, false em LXC local)
DATABASE_SSL=false

# Chave secreta JWT — TROQUE antes de usar em produção!
JWT_SECRET=troque_essa_chave_por_algo_seguro_com_32_ou_mais_chars

# Porta do servidor Node.js
PORT=3001

# Ambiente
NODE_ENV=production
