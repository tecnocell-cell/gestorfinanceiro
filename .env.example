# ──────────────────────────────────────────────
#  Gestor Financeiro — Variáveis de Ambiente
#  Copie para .env e preencha os valores reais
# ──────────────────────────────────────────────

# Conexão PostgreSQL
DATABASE_URL=postgresql://gestor:gestor123@localhost:5432/gestor_db

# SSL para PostgreSQL (true em produção com certificado, false em LXC local)
DATABASE_SSL=false

# Chave secreta JWT — TROQUE antes de usar em produção!
JWT_SECRET=troque_essa_chave_por_algo_seguro_com_32_ou_mais_chars

# Porta do servidor Node.js (backend)
PORT=3001

# Ambiente
NODE_ENV=production

# Login suspeito (OTP): false desativa verificação extra no login
# SUSPICIOUS_LOGIN=false

# Origens permitidas no CORS (várias URLs separadas por vírgula)
# CORS_ORIGIN=https://gestor.suaempresa.com,https://app.suaempresa.com,https://centerflow.app,https://www.centerflow.app

# ── Verificação de cadastro (e-mail) ──
# EMAIL_PROVIDER=smtp|resend|console   # auto: resend se RESEND_API_KEY, senão smtp se SMTP_HOST, senão console
# EMAIL_FROM="Fluxiva <noreply@suaempresa.com>"
# RESEND_API_KEY=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu@gmail.com
# SMTP_PASS=senha_de_app
# SMTP_FROM="Fluxiva <noreply@suaempresa.com>"
# APP_URL=https://app.fluxiva.com.br
# VERIFY_CODE_TTL_MIN=15
# EMAIL_VERIFY_TOKEN_TTL_HOURS=24
# PASSWORD_RESET_TTL_MIN=60
# EMPRESA_CONVITE_TTL_DAYS=7

# ── Verificação por SMS (Twilio) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+5511999999999

# ── WhatsApp Financeiro (Evolution API ou WhatsApp-Gateway) ──
# URL base do serviço WhatsApp (sem barra no final).
# Pode ser Evolution self-hosted OU WhatsApp-Gateway (ex: http://IP_DO_GATEWAY:8081)
# EVOLUTION_API_URL=http://127.0.0.1:8081
# API key — na Evolution: Manager > API Keys; no Gateway: API_KEY (mesmo valor nos dois)
# EVOLUTION_API_KEY=
# Instância usada para OTP de segurança (login suspeito, verificar telefone)
# WHATSAPP_OTP_INSTANCE=cf-admin
# WHATSAPP_ADMIN_INSTANCE=cf-admin
# URL pública do app — links em e-mails (verificação, convite, reset)
# APP_URL=https://gestor.suaempresa.com

# ── IA / Processamento de mídia WhatsApp ──
# Chave da OpenAI (Whisper para áudio + GPT-4o-mini para comprovantes)
# Se ausente, o sistema usa o provider mock (retorna null, sem transcrição/OCR).
# OPENAI_API_KEY=sk-...

# Provider de transcrição de áudio: openai | mock  (default: openai se OPENAI_API_KEY)
# TRANSCRIPTION_PROVIDER=openai

# Provider de OCR de comprovantes: openai | mock  (default: openai se OPENAI_API_KEY)
# OCR_PROVIDER=openai

# Caminho base onde o Gateway salva arquivos de mídia (mesmo SESSIONS_DIR do Gateway).
# Usado pelo CenterFlow para localizar arquivos localmente (fallback dev).
# GATEWAY_SESSIONS_DIR=/caminho/para/whatsapp-gateway/sessions

# Ativar fallback local de mídia em desenvolvimento (true | false)
# MEDIA_LOCAL_FALLBACK=false

# ── Cobrança / Assinaturas (Etapa 6.5 — Asaas) ──
# ASAAS_API_KEY=                           # API key do painel Asaas
# ASAAS_ENV=sandbox                        # sandbox | production
# ASAAS_WEBHOOK_TOKEN=                     # Token opcional no webhook (header asaas-access-token)
# BILLING_USE_MOCK_GATEWAY=true            # Dev/testes sem API real (gera PIX mock)
# BILLING_ALLOW_SIMULATE=true              # Permite POST /billing/assinatura/simular em produção

# ── Open Finance (Etapa 6.4 — Pluggy) ──
# Configuração ÚNICA do servidor Fluxiva (admin). Usuários finais NÃO preenchem estas variáveis.
# mock = Banco Demo Fluxiva | pluggy = conexão real via provedor
# OPENFINANCE_PROVIDER=mock
# OPENFINANCE_CLIENT_ID=
# OPENFINANCE_CLIENT_SECRET=
# OPENFINANCE_BASE_URL=https://api.pluggy.ai
# OPENFINANCE_OAUTH_REDIRECT_URL=
# OPENFINANCE_WEBHOOK_URL=
